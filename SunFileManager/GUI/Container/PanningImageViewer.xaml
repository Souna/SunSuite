<UserControl x:Class="SunFileManager.GUI.Container.PanningImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="100" MinHeight="100">
    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <ScrollViewer x:Name="scrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="Both">
            <Image x:Name="displayImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   MouseLeftButtonDown="displayImage_MouseLeftButtonDown"
                   MouseMove="displayImage_MouseMove"
                   MouseLeftButtonUp="displayImage_MouseLeftButtonUp"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </ScrollViewer>
    </Border>
</UserControl>
