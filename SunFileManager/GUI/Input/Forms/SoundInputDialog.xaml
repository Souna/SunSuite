<Window x:Class="SunFileManager.GUI.Input.frmSoundInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Sound" Width="360" Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <Label Content="Name:" />
        <TextBox x:Name="txtNameInput" Margin="0,4,0,8" />
        <Label Content="Sound File:" />
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSoundPath" Grid.Column="0" IsReadOnly="True" />
            <Button Grid.Column="2" Content="Browse..." Click="btnBrowse_Click" />
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     x:Name="btnOk"     Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="btnOk_Click" />
            <Button Content="Cancel" x:Name="btnCancel" Width="80"
                    IsCancel="True"  Click="btnCancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
