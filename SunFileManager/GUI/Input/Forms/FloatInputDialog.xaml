<Window x:Class="SunFileManager.GUI.Input.Forms.frmFloatInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Float Input" Width="300" Height="170"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <Label Content="Name:" />
        <TextBox x:Name="txtNameInput" Margin="0,4,0,8" />
        <Label Content="Value (decimal):" />
        <TextBox x:Name="txtFloatValueInput" Margin="0,4,0,0" Text="0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     x:Name="btnOk"     Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="btnOk_Click" />
            <Button Content="Cancel" x:Name="btnCancel" Width="80"
                    IsCancel="True"  Click="btnCancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
