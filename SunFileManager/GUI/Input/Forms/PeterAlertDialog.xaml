<Window x:Class="SunFileManager.GUI.Input.Forms.frmPeterAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hey!" Width="250" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Image Grid.Row="0"
               Source="pack://application:,,,/Resources/peter.gif"
               Stretch="Uniform" />
        <Button Grid.Row="1" Content="OK" Width="80" Margin="0,8,0,0"
                HorizontalAlignment="Center"
                IsDefault="True" IsCancel="True" Click="btnOk_Click"/>
    </Grid>
</Window>
