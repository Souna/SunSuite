<Window x:Class="SunFileManager.GUI.frmNewFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New SunFile" Width="300" Height="150"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <Label Content="File Name:" />
        <TextBox x:Name="txtFileName" Margin="0,4,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Create" x:Name="btnCreate" Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="btnCreate_Click" />
            <Button Content="Cancel" x:Name="btnCancel" Width="80"
                    IsCancel="True"  Click="btnCancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
