<Window x:Class="SunFileManager.GUI.Input.Forms.frmNameValueInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Name + Value Input" Width="320" Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <Label Content="Name:" />
        <TextBox x:Name="txtNameInput" Margin="0,4,0,8" />
        <Label Content="Value:" />
        <TextBox x:Name="txtStringValueInput" Margin="0,4,0,0"
                 Height="60" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     x:Name="btnOk"     Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="btnOk_Click" />
            <Button Content="Cancel" x:Name="btnCancel" Width="80"
                    IsCancel="True"  Click="btnCancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
