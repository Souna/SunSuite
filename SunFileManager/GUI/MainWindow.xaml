<local:SunFluentWindow x:Class="SunFileManager.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:container="clr-namespace:SunFileManager.GUI.Container"
        xmlns:local="clr-namespace:SunFileManager.GUI"
        Width="960" Height="640" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Menu -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────────────────────────── -->
        <ui:TitleBar Grid.Row="0" Title="SunFile Manager"/>

        <!-- ── Menu ──────────────────────────────────────────────────────────── -->
        <Menu Grid.Row="1">
            <MenuItem Header="_File">
                <MenuItem Header="_New"    Click="menuNew_Click"    InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open"   Click="menuOpen_Click"   InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save"   Click="menuSave_Click"   InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Export" Click="menuExport_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Add _Directory" Click="menuAddDirectory_Click"/>
                <MenuItem Header="Add _Image"     Click="menuAddImage_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Settings" Click="menuSettings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Help"  Click="menuHelp_Click"/>
                <MenuItem Header="_About" Click="menuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ── Main content ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="225" MinWidth="120"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"   MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Tree -->
            <TreeView x:Name="sunTreeView"
                      Grid.Column="0"
                      AllowDrop="True"
                      DragEnter="sunTreeView_DragEnter"
                      Drop="sunTreeView_Drop"
                      SelectedItemChanged="sunTreeView_SelectedItemChanged"
                      MouseRightButtonUp="sunTreeView_MouseRightButtonUp"
                      KeyDown="sunTreeView_KeyDown"
                      MouseDoubleClick="sunTreeView_DoubleClick"
                      PreviewMouseDown="sunTreeView_PreviewMouseDown"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding IconSource}"
                                   Width="16" Height="16" Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="Name"/>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManuallyAdded}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Style.Triggers>
                            <!-- Multi-select highlight -->
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource SystemAccentColorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Right: Property panel -->
            <Grid Grid.Column="2" Margin="8,4,8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Selection type -->
                    <RowDefinition Height="Auto"/>  <!-- Name row -->
                    <RowDefinition Height="Auto"/>  <!-- Value row -->
                    <RowDefinition Height="Auto"/>  <!-- Vector row -->
                    <RowDefinition Height="*"/>     <!-- Image / Sound -->
                    <RowDefinition Height="Auto"/>  <!-- Apply button -->
                </Grid.RowDefinitions>

                <!-- Selection type -->
                <TextBlock x:Name="lblSelectedNodeType" Grid.Row="0"
                           Text="Selection Type: "
                           Margin="0,4,0,8" FontStyle="Italic"/>

                <!-- Name row -->
                <StackPanel x:Name="nameRow" Grid.Row="1" Orientation="Horizontal"
                            Visibility="Collapsed" Margin="0,0,0,6">
                    <Label Content="Name:" Width="60" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPropertyName" Width="200" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Scalar value row -->
                <StackPanel x:Name="scalarValueRow" Grid.Row="2" Orientation="Horizontal"
                            Visibility="Collapsed" Margin="0,0,0,6">
                    <Label Content="Value:" Width="60" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPropertyValue" Width="200" VerticalAlignment="Center"
                             AcceptsReturn="False"/>
                </StackPanel>

                <!-- Multiline value row (string / link) -->
                <StackPanel x:Name="multiValueRow" Grid.Row="2"
                            Visibility="Collapsed" Margin="0,0,0,6">
                    <Label Content="Value:"/>
                    <TextBox x:Name="txtPropertyValueMulti"
                             Height="80" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Vector row -->
                <Grid x:Name="vectorRow" Grid.Row="3"
                      Visibility="Collapsed" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="X:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="txtVectorX" VerticalAlignment="Center"/>
                    <Label Grid.Column="3" Content="Y:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" x:Name="txtVectorY" VerticalAlignment="Center"/>
                </Grid>

                <!-- Image viewer -->
                <container:PanningImageViewer x:Name="panningImageViewer"
                                              Grid.Row="4"
                                              Visibility="Collapsed"
                                              Margin="0,0,0,6"/>

                <!-- Sound player -->
                <local:SoundPlayer x:Name="soundPlayer"
                                   Grid.Row="4"
                                   Visibility="Collapsed"
                                   Margin="0,4,0,6"/>

                <!-- Apply button -->
                <Button x:Name="btnApplyPropertyChanges"
                        Grid.Row="5"
                        Content="Apply"
                        Width="80"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed"
                        Click="btnApplyPropertyChanges_Click"/>
            </Grid>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────────────── -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="statusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</local:SunFluentWindow>
